body {
    background-color: #000;
    color: #fff;
    font-family: 'Courier New', monospace; /* Authentic terminal font */
    padding: 20px;
    line-height: 1.6;
}

.container {
    display: flex; /* Creates the two-column layout from photos */
    gap: 40px;
}

.ascii-portrait, .content {
    width: 50%;
}

pre {
    color: #888; /* Slightly dimmer for portrait */
    margin: 0;
}

pre.ascii-logo {
    color: #fff; /* Keep logo bright */
}

h1 {
    font-size: 2em;
    margin-bottom: 20px;
}

p {
    margin-bottom: 15px;
}

nav {
    margin-top: 30px;
    display: flex;
    gap: 20px;
}

nav span {
    color: #fff; /* Base nav text color */
}

nav span:hover {
    text-decoration: underline; /* Add underline on hover */
    cursor: pointer;
}

nav span.active {
    color: #00ffff; /* Make one link cyan to start, like selected */
}
